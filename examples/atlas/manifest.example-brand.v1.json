{
  "schemaVersion": "atlas.manifest/v1",
  "metadata": {
    "manifestId": "example-app.mobile.catalog.brand-aware.v1",
    "productId": "example-app",
    "productName": "ExampleApp",
    "platformFamily": "mobile",
    "owner": "design-systems",
    "description": "Example Atlas manifest fixture showing how Atlas can bind Brandie review metadata without giving Sentinel ownership of the brand system.",
    "revision": 1
  },
  "paths": [
    {
      "id": "main:journey:list",
      "kind": "surface",
      "title": "Workouts list",
      "segments": [
        { "kind": "root", "value": "main", "label": "Main" },
        { "kind": "group", "value": "journey", "label": "Journey" },
        { "kind": "surface", "value": "list", "label": "List" }
      ]
    }
  ],
  "scenarios": [
    {
      "id": "journey:list:default",
      "presetId": "list",
      "scope": "shared",
      "title": "Default list"
    },
    {
      "id": "journey:list:empty-journey",
      "presetId": "list",
      "scope": "product-extension",
      "title": "Empty journey list",
      "description": "Review this state with the Brandie-backed empty-state treatment attached by Atlas."
    }
  ],
  "targets": [
    {
      "id": "ios:iphone15pro:light:en-gb",
      "platform": "ios",
      "deviceClass": "phone",
      "deviceName": "iPhone 15 Pro",
      "viewport": { "width": 393, "height": 852 },
      "locale": "en-GB",
      "appearance": "light",
      "orientation": "portrait"
    },
    {
      "id": "android:pixel8:light:en-gb",
      "platform": "android",
      "deviceClass": "phone",
      "deviceName": "Pixel 8",
      "viewport": { "width": 412, "height": 915 },
      "locale": "en-GB",
      "appearance": "light",
      "orientation": "portrait"
    }
  ],
  "entryStrategies": [
    {
      "id": "journey:list:deeplink",
      "kind": "deepLink",
      "title": "Open workouts list"
    }
  ],
  "surfaces": [
    {
      "id": "journey:list",
      "kind": "screen",
      "title": "Workouts list",
      "pathId": "main:journey:list",
      "scenarioIds": [
        "journey:list:default",
        "journey:list:empty-journey"
      ],
      "targetIds": [
        "ios:iphone15pro:light:en-gb",
        "android:pixel8:light:en-gb"
      ],
      "entryStrategyIds": [
        "journey:list:deeplink"
      ],
      "scenarioPresetIds": [
        "preset.list.default",
        "preset.list.empty"
      ]
    },
    {
      "id": "journey:empty-state",
      "kind": "overlay",
      "title": "Journey empty state",
      "pathId": "main:journey:list",
      "scenarioIds": [
        "journey:list:empty-journey"
      ],
      "targetIds": [
        "ios:iphone15pro:light:en-gb"
      ],
      "entryStrategyIds": [
        "journey:list:deeplink"
      ],
      "scenarioPresetIds": [
        "preset.list.empty"
      ]
    }
  ],
  "reviewContext": {
    "owner": "atlas",
    "sources": [
      {
        "id": "brandie:example-app.review-pack",
        "kind": "brandie-review-pack",
        "contractPath": "brands/brandie/review-assets/contract.json",
        "packId": "example-app.review-pack",
        "packPath": "brands/brandie/review-assets/packs/example-app.json",
        "brandReference": "brands/brandie/review-assets/contract.json#brandDefaults"
      }
    ],
    "bindings": [
      {
        "id": "journey:empty-state:brandie-review",
        "sourceId": "brandie:example-app.review-pack",
        "surfaceId": "journey:empty-state",
        "scenarioId": "journey:list:empty-journey",
        "sourceKind": "scenario-override",
        "atlasNamespaceRef": "atlas.example-app.journey.progress-photos-empty",
        "surfaceFamily": "journey",
        "reviewState": "empty",
        "assetKind": "empty-state",
        "sourceScreenId": "progress-photos-empty",
        "voiceContext": {
          "headline": "No progress photos yet",
          "body": "Capture your first private check-in to start a like-for-like timeline.",
          "tone": "warm and encouraging",
          "formality": "casual but respectful",
          "humor": "light and playful",
          "firstPerson": false
        },
        "mascot": {
          "id": "hue",
          "poseId": "puzzled",
          "promptId": "hue-puzzled"
        },
        "illustration": {
          "role": "journey progress empty state",
          "alt": "Hue inspects an empty progress timeline",
          "assetRef": "brands/brandie/assets/manifest.json#progress-photos-empty"
        }
      }
    ]
  }
}
